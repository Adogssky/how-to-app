.picker-wrap {
  min-height: 100vh;
  background: var(--bg);
}

.search-box {
  padding: 24rpx 32rpx;
}

.search-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 1rpx solid var(--line);
  border-radius: 50rpx;
  background: var(--surface-solid);
  font-size: 30rpx;
  box-sizing: border-box;
  line-height: 88rpx;
}

.category-chips {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.category-chip {
  flex: 0 0 auto;
  display: inline-flex;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: 1rpx solid var(--line);
  background: var(--surface-solid);
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  margin: 0;
  line-height: 1;
}

.category-chip.active {
  background: var(--text);
  color: #fff;
  border-color: var(--text);
}

.exercise-results {
  padding: 0 32rpx 160rpx;
}

.result-item {
  background: var(--surface-solid);
  border: 1rpx solid var(--line);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.result-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.result-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.result-thumb image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
  object-fit: cover;
}

.result-info {
  flex: 1;
}

.result-name {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.result-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.result-select {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  background: var(--text);
  color: #fff;
  font-size: 26rpx;
  border: none;
}

.result-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--text-secondary);
  font-size: 30rpx;
}
