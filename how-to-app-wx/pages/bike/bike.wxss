.bike-wrap {
  min-height: 100vh;
  background: var(--bg);
}

.bike-content {
  padding: 32rpx;
}

.choice-card {
  background: var(--surface-solid);
  border: 1rpx solid var(--line);
  border-radius: var(--radius);
  padding: 48rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}

.choice-icon {
  font-size: 72rpx;
}

.choice-label {
  font-size: 40rpx;
  font-weight: 800;
}

.bike-detail {
  padding: 32rpx;
}

.bike-detail .title {
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
}

.bike-detail .desc {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.part-card {
  background: var(--surface-solid);
  border: 1rpx solid var(--line);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.part-card .name {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.part-card .desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}
