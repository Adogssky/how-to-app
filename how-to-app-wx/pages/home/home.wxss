.home-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 200rpx;
  box-sizing: border-box;
  background: var(--bg);
}

.home-hero {
  text-align: center;
  margin-bottom: 40rpx;
}

.main-question {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1.1;
}

.main-question .accent {
  color: var(--primary);
}

.main-subtitle {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.home-swiper {
  width: 100%;
  height: 800rpx;
}

.home-swiper-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.program-card {
  width: 82%;
  height: 720rpx;
  background: var(--surface-solid);
  border: 1rpx solid var(--line);
  border-radius: var(--radius);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.program-card.gradient-1 { background: linear-gradient(160deg, #ffffff 0%, var(--c-lavender) 100%); }
.program-card.gradient-2 { background: linear-gradient(160deg, #ffffff 0%, var(--c-sky) 100%); }

.card-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-icon {
  font-size: 112rpx;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.card-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--line);
}

.vote-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 16rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--line);
  background: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

.vote-like { color: var(--success); }
.vote-dislike { color: var(--danger); }

.vote-dots {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.vote-cluster {
  width: 10rpx;
  height: 22rpx;
  border-radius: 6rpx;
}

.vote-count {
  font-size: 22rpx;
  font-weight: 700;
}

.home-controls {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.refresh-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 1rpx solid var(--line);
  background: var(--surface-solid);
  color: var(--text-secondary);
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.refresh-btn.disabled {
  opacity: 0.35;
}

.more-btn {
  background: var(--text);
  color: #fff;
  border-radius: 50rpx;
  padding: 30rpx 64rpx;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.more-btn:active {
  opacity: 0.9;
}
