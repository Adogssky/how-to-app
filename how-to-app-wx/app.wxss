/* ===== Design tokens ===== */
page {
  --bg: #f6f4f1;
  --surface: rgba(255, 255, 255, 0.78);
  --surface-solid: #ffffff;
  --text: #171717;
  --text-secondary: #818181;
  --line: rgba(0, 0, 0, 0.07);
  --line-strong: rgba(0, 0, 0, 0.16);

  --c-lavender: #e4def5;
  --c-sky: #cfe5f6;
  --c-mint: #cce9e0;
  --c-peach: #f5dccf;
  --c-rose: #edd3dd;

  --primary: #6b5ce7;
  --success: #5cb38f;
  --danger: #e06c75;
  --accent: #d99a5e;

  --radius: 28rpx;
  --radius-sm: 18rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 32rpx;
  box-sizing: border-box;
}

/* ===== Buttons ===== */
.btn-primary {
  background: var(--text);
  color: #fff;
  border-radius: 50rpx;
  padding: 28rpx 56rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-text {
  background: transparent;
  color: var(--text-secondary);
  font-size: 28rpx;
  border: none;
}

/* ===== Cards ===== */
.card {
  background: var(--surface-solid);
  border: 1rpx solid var(--line);
  border-radius: var(--radius);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

/* ===== Nav bar replacement ===== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  flex: 1;
  margin: 0 24rpx;
}

.nav-btn {
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--surface);
  border: 1rpx solid var(--line);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text);
  padding: 0;
  margin: 0;
  line-height: 1;
}

.nav-btn.plain {
  background: transparent;
  border: none;
}
